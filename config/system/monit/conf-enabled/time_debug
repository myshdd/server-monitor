check program time_check with path "/bin/sh -c 'timedatectl show -p NTPSynchronized --value | grep -q yes && echo OK'"
    if status != 0 then exec "/opt/server-monitor/scripts/system/monit-telegram-direct.py '⚠️ [TIMEDATECTL] Время не синхронизировано!'"
    if status == 0 then exec "/opt/server-monitor/scripts/system/monit-telegram-direct.py '✅ [TIMEDATECTL] Время синхронизировано!'"
