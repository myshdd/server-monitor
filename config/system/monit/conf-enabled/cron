check process cron with pidfile /var/run/crond.pid
    start program = "/usr/bin/systemctl start cron"
    stop program = "/usr/bin/systemctl stop cron"
    if not exist for 2 cycles then exec "/usr/local/bin/monit-alert.sh '⚠️ Cron не работает! Запланированные задачи не выполняются.'"
    if exist for 2 cycles then exec "/usr/local/bin/monit-alert.sh '✅ Cron сервис восстановлен!'"
