check process cron with pidfile /var/run/crond.pid
    start program = "/usr/bin/systemctl start cron"
    stop program = "/usr/bin/systemctl stop cron"
    if not exist for 2 cycles then exec "/opt/server-monitor/scripts/system/monit-telegram-direct.py '⚠️ Cron не работает! Запланированные задачи не выполняются.'"
    if exist for 2 cycles then exec "/opt/server-monitor/scripts/system/monit-telegram-direct.py '✅ Cron сервис восстановлен!'"
