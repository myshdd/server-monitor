check program xray with path "/bin/sh -c 'docker ps --format \"{{.Names}}\" | grep -q amnezia-xray && echo OK'"
    start program = "/usr/bin/docker start amnezia-xray"
    stop program = "/usr/bin/docker stop amnezia-xray"
    if status != 0 for 2 cycles then exec "/opt/server-monitor/scripts/system/monit-telegram-direct.py '⚠️ Xray контейнер остановлен!'"
    if status == 0 for 2 cycles then exec "/opt/server-monitor/scripts/system/monit-telegram-direct.py '✅ Xray контейнер восстановлен!'"
    if 3 restarts within 5 cycles then exec "/opt/server-monitor/scripts/system/monit-telegram-direct.py '🚨 Xray: слишком много перезапусков!'"
