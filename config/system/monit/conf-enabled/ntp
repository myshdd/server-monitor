check process timesyncd matching "systemd-timesyncd"
    if not exist for 2 cycles then exec "/usr/local/bin/monit-alert.sh '⚠️ Служба синхронизации времени не работает!'"
    if exist for 2 cycles then exec "/usr/local/bin/monit-alert.sh '✅ Служба синхронизации времени восстановлена!'"

check file timesync_sync with path /var/run/systemd/timesync/synchronized
    if does not exist for 2 cycles then exec "/usr/local/bin/monit-alert.sh '⚠️ Время не синхронизировано с NTP сервером!'"
    if exist for 2 cycles then exec "/usr/local/bin/monit-alert.sh '✅ Время синхронизировано с NTP сервером!'"
