check process rsyslog matching "rsyslogd"
    start program = "/usr/bin/systemctl start rsyslog"
    stop program = "/usr/bin/systemctl stop rsyslog"
    if not exist for 2 cycles then exec "/opt/server-monitor/scripts/system/monit-telegram-direct.py '⚠️ Rsyslog не работает! Логи могут не писаться.'"
    if exist for 2 cycles then exec "/opt/server-monitor/scripts/system/monit-telegram-direct.py '✅ Rsyslog сервис восстановлен!'"
